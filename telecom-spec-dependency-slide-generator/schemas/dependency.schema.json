{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dependency",
  "type": "object",
  "required": ["from", "to", "type", "criticality", "confidence", "explicit", "evidence"],
  "properties": {
    "from": { "type": "string" },
    "to": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "prerequisite",
        "functional",
        "interface",
        "integration",
        "data",
        "process",
        "event",
        "regulatory",
        "blocking",
        "upstream",
        "downstream"
      ]
    },
    "criticality": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "explicit": { "type": "boolean" },
    "interdomain": { "type": "boolean" },
    "source_section": { "type": "string" },
    "evidence": { "type": "string" }
  }
}
